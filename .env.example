# Core
# DATABASE_URL format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/app
# TEST_DATABASE_URL format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
TEST_DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/app_test
SECRET_KEY=change-me
AUTO_CREATE_DB=true

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_SERVICE_NAME=agent
LOG_ENVIRONMENT=development

# Sessions
SESSION_TYPE=filesystem
SESSION_FILE_DIR=sessions
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
SESSION_USE_SIGNER=true
SESSION_PERMANENT=false
SESSION_LIFETIME_DAYS=7
SESSION_REFRESH_EACH_REQUEST=true
CSRF_HEADER_NAME=X-CSRF-Token  # 前端写操作请求携带的 CSRF 头名

# CORS（前后端分离联调）
FRONTEND_DEV_PORT=5173
CORS_ENABLED=true
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,X-CSRF-Token,Authorization
CORS_EXPOSE_HEADERS=
CORS_MAX_AGE_SECONDS=600

# Avatar
AVATAR_UPLOAD_DIR=uploads/avatars
AVATAR_BASE_URL=/uploads/avatars

# Email (QQ SMTP example)
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your@qq.com
SMTP_PASSWORD=your_authorization_code
SMTP_FROM=your@qq.com

# Agent runtime（主模型与子 Agent 模型）
# 这些设置从项目根目录 .env 加载；如果不区分角色模型，可只填写通用 AI_*。
# Main/Search/MCP 未单独配置时会回退到 AI_*。
# 对话模型，provider 最好使用 openai 兼容接口。
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT_SECONDS=120

# Report agent runtime（正式报告生成）
AGENT_REPORT_AI_PROVIDER=
AGENT_REPORT_AI_MODEL=
AGENT_REPORT_AI_API_KEY=
AGENT_REPORT_AI_BASE_URL=
AGENT_REPORT_AI_TIMEOUT_SECONDS=120

# Main agent runtime（规划 / 汇总）
AGENT_MAIN_AI_PROVIDER=
AGENT_MAIN_AI_MODEL=
AGENT_MAIN_AI_API_KEY=
AGENT_MAIN_AI_BASE_URL=
AGENT_MAIN_AI_TIMEOUT_SECONDS=120

# Search subagent runtime（RAG / Web 搜索）
AGENT_SEARCH_AI_PROVIDER=
AGENT_SEARCH_AI_MODEL=
AGENT_SEARCH_AI_API_KEY=
AGENT_SEARCH_AI_BASE_URL=
AGENT_SEARCH_AI_TIMEOUT_SECONDS=120

# MCP subagent runtime（MCP 能力发现 / 调用）
AGENT_MCP_AI_PROVIDER=
AGENT_MCP_AI_MODEL=
AGENT_MCP_AI_API_KEY=
AGENT_MCP_AI_BASE_URL=
AGENT_MCP_AI_TIMEOUT_SECONDS=120

AGENT_AUTO_TOOL_SELECTION_ENABLED=true
AGENT_TOOL_CALL_MAX_ROUNDS=4
AGENT_CHAT_JOBS_ENABLED=true
AGENT_CHAT_JOB_WORKERS=2
AGENT_CHAT_JOBS_SYNC_EXECUTION=false

# Agent websearch（联网搜索，依赖 Tavily）
AGENT_WEBSEARCH_ENABLED=false
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com/search
TAVILY_TIMEOUT_SECONDS=15

# Agent MCP（外部工具/服务调用）
AGENT_MCP_ENABLED=false
# JSON object, e.g. {"local":{"endpoint":"http://127.0.0.1:8080/mcp"}}
AGENT_MCP_SERVERS_JSON=
AGENT_MCP_TIMEOUT_SECONDS=20

# Knowledge Graph runtime
# 开启后，工作台聊天会注册知识图谱工具；传 entity / intent 或在消息中提到“知识图谱”会优先走图查询。
AGENT_KNOWLEDGE_GRAPH_ENABLED=false
# 为 true 时，命中聊天请求后直接走知识图谱，不再经过 planner。
AGENT_KNOWLEDGE_GRAPH_DIRECT_ONLY=false

# Knowledge Graph query backend (Neo4j)
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Knowledge Graph query LLM (Spark)
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_URL=wss://spark-api.xf-yun.com/v3.5/chat
SPARK_MODEL=generalv3.5

# Knowledge Graph query tuning
QUERY_TIMEOUT_SECONDS=30
GRAPH_QUERY_TOP_K=20
ENHANCED_SCHEMA=false
ALLOW_DANGEROUS_REQUESTS=true
SUPPRESS_NEO4J_DEPRECATION_WARNING=true

# Bankruptcy analysis
BANKRUPTCY_ANALYSIS_ENABLED=false
BANKRUPTCY_MODEL_PATH=assets/bankruptcy/model/xgb_borderline_smote.pkl
BANKRUPTCY_SCALER_PATH=assets/bankruptcy/model/scaler_borderline_smote.pkl
BANKRUPTCY_THRESHOLD=0.63
BANKRUPTCY_TOP_FEATURE_COUNT=10
BANKRUPTCY_UPLOAD_DIR=uploads/bankruptcy/csv
BANKRUPTCY_PLOT_DIR=uploads/bankruptcy

# Codes（验证码/注册登录）
CODE_TTL_SECONDS=600
CODE_RESEND_COOLDOWN_SECONDS=60
CODE_LOCKOUT_SECONDS=600
CODE_MAX_ATTEMPTS=5
MIN_PASSWORD_LENGTH=8

# RAG（检索增强生成）
# 保证开启 RAG，进入检索/重排/分块流程。
RAG_ENABLED=true
# 前端可视化（检索调试面板）
RAG_DEBUG_VISUALIZATION_ENABLED=false
RAG_VECTOR_PROVIDER=chromadb
RAG_EMBEDDER_PROVIDER=openai-compatible
RAG_RERANKER_PROVIDER=openai-compatible
# 确保嵌入和重排模型为专用模型，不是一般llm，推荐使用qwen系列模型
# 嵌入模型（生成向量）
RAG_EMBEDDING_MODEL=
RAG_EMBEDDING_VERSION=1
RAG_EMBEDDING_DIMENSION=
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_TIMEOUT_SECONDS=120
# 重排序模型（对候选片段重新排序）
RAG_RERANKER_MODEL=
RAG_RERANKER_API_KEY=
RAG_RERANKER_BASE_URL=
RAG_RERANKER_TIMEOUT_SECONDS=120
RAG_RETRIEVAL_TOP_K=5
RAG_RETRIEVAL_SCORE_THRESHOLD=-1.0
RAG_ALLOWED_FILE_TYPES=pdf,docx,md,txt
RAG_UPLOAD_DIR=RAGDIR/rag
RAG_FILELOADER_VERSION=v1
RAG_AUTO_INDEX_ON_UPLOAD=true
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_CHUNK_STRATEGY_DEFAULT=paragraph
RAG_CHUNK_STRATEGY_ALLOWED=paragraph,semantic_llm
RAG_CHUNK_FALLBACK_STRATEGY=paragraph
RAG_CHUNK_VERSION=v1
RAG_CHUNK_SEMANTIC_TARGET_TOKENS=450
RAG_CHUNK_SEMANTIC_MAX_TOKENS=700
RAG_CHUNK_SEMANTIC_OVERLAP_TOKENS=50
RAG_CHUNK_SEMANTIC_MIN_TOKENS=120
RAG_CHUNK_AI_PROVIDER=noop|openai
# 分块模型（结构化/语义分块）
RAG_CHUNK_AI_MODEL=
RAG_CHUNK_AI_API_KEY=
RAG_CHUNK_AI_BASE_URL=
RAG_CHUNK_AI_TIMEOUT_SECONDS=120
# PDF OCR：对原生提取失败的页面走 OCR。关闭后扫描件 PDF 会失败。填写disable会完全关闭 OCR 功能。
RAG_OCR_PROVIDER=openai-compatible
# 这里应填写支持图片识别的视觉模型。
RAG_OCR_MODEL=
RAG_OCR_API_KEY=
RAG_OCR_BASE_URL=
RAG_OCR_TIMEOUT_SECONDS=120
RAG_INDEX_MAX_WORKERS=2
RAG_CHROMADB_PERSIST_DIR=RAGDIR/chromadb
RAG_CHROMADB_COLLECTION_PREFIX=rag

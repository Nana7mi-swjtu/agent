<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agent Studio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=gg+sans:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      /* ─── Discord design tokens ─── */
      :root {
        /* surfaces */
        --bg-sidebar-server: #1e1f22;
        --bg-sidebar-channel: #2b2d31;
        --bg-main: #313338;
        --bg-overlay: #232428;
        --bg-input:  #383a40;
        /* borders */
        --line: #3f4147;
        /* text */
        --text: #f2f3f5;
        --text-muted: #949ba4;
        --text-header: #f2f3f5;
        --text-channel: #949ba4;
        /* brand */
        --accent: #5865f2;
        --accent-2: #7b86ff;
        --ok: #23a559;
        --danger: #f23f43;
        /* misc */
        --scrollbar: #1a1b1e;
        --hover-pill: rgba(79,84,92,.16);
        --selected-pill: rgba(79,84,92,.32);
        --radius: 4px;
      }

      /* ─── Reset & base ─── */
      *, *::before, *::after { box-sizing: border-box; }

      html, body { height: 100%; margin: 0; overflow: hidden; }

      body {
        color: var(--text);
        background: var(--bg-main);
        font-family: "gg sans", "Noto Sans SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: 16px;
        line-height: 1.375;
        -webkit-font-smoothing: antialiased;
      }

      #app { height: 100%; }

      .container {
        width: min(780px, 100%);
        margin: 0 auto;
        background: linear-gradient(180deg, color-mix(in srgb, var(--panel) 94%, black), var(--panel));
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 18px;
        box-shadow: var(--shadow);
      }

      .auth-box {
        margin-top: 24px;
        width: min(520px, 100%);
      }

      .auth-stage {
        min-height: calc(100vh - 32px);
        display: grid;
        align-items: center;
      }

      .auth-hero {
        position: relative;
        overflow: hidden;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: linear-gradient(135deg, #2b2d31, #1e1f22);
      }

      .auth-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 20% 20%, rgba(88, 101, 242, 0.3), transparent 38%),
          radial-gradient(circle at 85% 75%, rgba(123, 134, 255, 0.22), transparent 38%);
        pointer-events: none;
      }

      .auth-hero.has-gif {
        background-size: cover;
        background-position: center;
      }

      .auth-mask {
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, rgba(10, 11, 14, 0.8), rgba(18, 19, 24, 0.66));
      }

      .auth-grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(260px, 1.1fr) minmax(340px, 1fr);
        gap: 20px;
        padding: 26px;
      }

      .auth-copy {
        display: grid;
        align-content: center;
        gap: 12px;
      }

      .auth-copy h1 {
        margin: 0;
        font-size: clamp(28px, 4vw, 44px);
        line-height: 1;
        letter-spacing: 0.01em;
      }

      .auth-copy p {
        margin: 0;
        color: #d4d8dd;
        max-width: 36ch;
      }

      .auth-card {
        background: color-mix(in srgb, var(--panel) 94%, black);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 18px;
        box-shadow: 0 16px 28px rgba(0, 0, 0, 0.3);
      }

      h2 {
        margin: 0 0 14px;
        font-size: clamp(22px, 3vw, 30px);
      }

      h3 {
        margin: 8px 0 10px;
        font-size: 16px;
      }

      form {
        display: grid;
        gap: 12px;
      }

      label {
        display: grid;
        gap: 7px;
        font-size: 13px;
        color: var(--muted);
        font-weight: 600;
      }

      input,
      select {
        width: 100%;
        border-radius: 10px;
        border: 1px solid var(--line);
        background: var(--panel-2);
        color: var(--text);
        font-size: 14px;
        padding: 11px 12px;
        outline: none;
      }

      input:focus,
      select:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 2px rgba(88, 101, 242, 0.28);
      }

      button {
        border: 0;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        font-weight: 700;
        color: #ffffff;
        background: linear-gradient(120deg, var(--accent), var(--accent-2));
        cursor: pointer;
      }

      button:hover:not(:disabled) {
        filter: brightness(1.06);
      }

      button:disabled {
        opacity: 0.7;
        cursor: not-allowed;
      }

      .note {
        margin: 6px 0 0;
        color: var(--muted);
        font-size: 13px;
      }

      .note a {
        color: #cdd5ff;
      }

      .error {
        margin: 4px 0 0;
        color: #ff9ea0;
        font-size: 13px;
      }

      .ai-layout {
        display: grid;
        grid-template-columns: 300px minmax(0, 1fr);
        gap: 12px;
        min-height: calc(100vh - 32px);
      }

      .sidebar {
        border-radius: 14px;
        background: var(--panel-3);
        border: 1px solid var(--line);
        padding: 12px;
        display: grid;
        grid-template-rows: auto auto 1fr auto;
        gap: 12px;
      }

      .sidebar-header {
        display: grid;
        gap: 8px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
      }

      .brand-dot {
        width: 11px;
        height: 11px;
        border-radius: 999px;
        background: var(--accent);
      }

      .side-block {
        display: grid;
        gap: 8px;
      }

      .side-block h4 {
        margin: 0;
        color: var(--muted);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .role-switch-list,
      .history-list,
      .side-actions {
        display: grid;
        gap: 8px;
      }

      .ghost-btn,
      .role-pill,
      .history-item {
        border: 1px solid var(--line);
        border-radius: 10px;
        background: var(--panel);
        color: var(--text);
        text-align: left;
      }

      .history-item span {
        color: var(--muted);
        font-size: 12px;
      }

      .history-list {
        max-height: 360px;
        overflow: auto;
      }

      .workspace-main {
        min-width: 0;
      }

      .workspace-stack {
        display: grid;
        gap: 12px;
        min-height: 100%;
      }

      .workspace-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: var(--panel-3);
        padding: 10px 12px;
      }

      .workspace-title {
        margin: 0;
        font-size: 16px;
      }

      .workspace-subtitle {
        margin: 2px 0 0;
        font-size: 12px;
        color: var(--muted);
      }

      .badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 8px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(120deg, var(--accent), var(--accent-2));
      }

      .card-muted {
        border: 1px solid var(--line);
        border-radius: 10px;
        background: var(--panel-2);
        padding: 10px;
      }

      .chat-composer {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
        align-items: end;
      }

      .chat-composer button {
        height: 42px;
      }

      .channel-shell {
        display: grid;
        gap: 0;
        border: 1px solid var(--line);
        border-radius: 14px;
        overflow: hidden;
        background: var(--panel);
      }

      .channel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px;
        border-bottom: 1px solid var(--line);
        background: color-mix(in srgb, var(--panel-3) 94%, black);
      }

      .channel-head-main {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
      }

      .channel-mark {
        font-size: 24px;
        line-height: 1;
        color: var(--muted);
        font-weight: 700;
      }

      .channel-name {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
      }

      .channel-topic {
        margin: 2px 0 0;
        color: var(--muted);
        font-size: 12px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 56ch;
      }

      .channel-feed {
        display: grid;
        gap: 2px;
        min-height: 420px;
        max-height: 62vh;
        overflow: auto;
        padding: 10px 0;
        background: linear-gradient(180deg, color-mix(in srgb, var(--panel) 94%, black), var(--panel));
      }

      .channel-empty {
        display: grid;
        align-content: end;
        min-height: 320px;
        padding: 18px 18px 22px;
      }

      .channel-empty h3 {
        margin: 0 0 8px;
        font-size: 28px;
      }

      .message-row {
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr);
        gap: 12px;
        padding: 8px 16px;
        transition: background 0.15s ease;
      }

      .message-row:hover {
        background: rgba(255, 255, 255, 0.02);
      }

      .message-avatar {
        width: 40px;
        height: 40px;
        border-radius: 999px;
        display: grid;
        place-items: center;
        font-size: 13px;
        font-weight: 800;
        color: #fff;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
      }

      .message-avatar.agent {
        background: linear-gradient(135deg, #3ba55d, #1f8b4c);
      }

      .message-meta {
        display: flex;
        align-items: baseline;
        gap: 8px;
        margin-bottom: 4px;
      }

      .message-author {
        font-size: 15px;
        font-weight: 700;
      }

      .message-time {
        color: var(--muted);
        font-size: 12px;
      }

      .message-text {
        margin: 0;
        line-height: 1.6;
        color: var(--text);
        white-space: pre-wrap;
        word-break: break-word;
      }

      .composer-shell {
        padding: 0 16px 16px;
        background: var(--panel);
      }

      .composer-box {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        align-items: end;
        padding: 10px;
        border-radius: 12px;
        background: var(--panel-2);
        border: 1px solid var(--line);
      }

      .composer-box label {
        gap: 6px;
      }

      .composer-hint {
        margin: 0 0 8px;
        color: var(--muted);
        font-size: 12px;
      }

      .composer-box button {
        min-width: 96px;
      }

      .chat-panel {
        margin: 12px 0;
        border: 1px solid var(--line);
        border-radius: 12px;
        min-height: 240px;
        background: var(--panel-2);
        padding: 12px;
        display: grid;
        gap: 8px;
      }

      .chat-line {
        border-radius: 10px;
        padding: 9px 10px;
        line-height: 1.55;
        font-size: 13px;
      }

      .chat-line.user {
        background: rgba(88, 101, 242, 0.22);
      }

      .chat-line.agent {
        background: rgba(94, 168, 255, 0.17);
      }

      .role-grid {
        margin: 12px 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 10px;
      }

      .role-card {
        min-height: 98px;
        border: 1px solid var(--line);
        background: var(--panel-2);
        border-radius: 12px;
        padding: 12px;
        color: var(--text);
        text-align: left;
      }

      .role-card span {
        display: block;
        margin-top: 7px;
        font-size: 12px;
        color: var(--muted);
      }

      .avatar-block {
        display: grid;
        gap: 8px;
        margin-bottom: 12px;
      }

      .avatar {
        width: 92px;
        height: 92px;
        border-radius: 999px;
        object-fit: cover;
        border: 2px solid var(--line);
      }

      .preset-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(56px, 1fr));
        gap: 8px;
        margin-bottom: 12px;
      }

      .avatar-item {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel-2);
        padding: 4px;
      }

      .avatar-item img {
        width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: 6px;
        object-fit: cover;
      }

      .switch-line {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .switch-line input {
        width: 16px;
        height: 16px;
      }

      hr {
        border: 0;
        border-top: 1px solid var(--line);
      }

      @media (max-width: 1000px) {
        .auth-grid {
          grid-template-columns: 1fr;
        }

        .ai-layout {
          grid-template-columns: 1fr;
        }

        .sidebar {
          min-height: auto;
        }
      }

      @media (max-width: 640px) {
        #app {
          padding: 10px;
        }

        .container,
        .auth-card {
          padding: 14px;
        }

        .auth-grid {
          padding: 14px;
          gap: 12px;
        }
      }
    </style>
  </head>
  <body>
    <div id="app"></div>
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="https://unpkg.com/vue-router@4/dist/vue-router.global.prod.js"></script>
    <script src="./app.js"></script>
  </body>
</html>
